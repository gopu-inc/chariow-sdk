{
  "name": "@chariow-sdk",
  "version": "2.0.0",
  "description": "Professional CLI for Chariow e-commerce platform - Manage products, track sales, and analyze metrics in real-time",
  "type": "module",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "bin": {
    "chariow": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "postinstall": "chmod +x dist/cli/index.js 2>/dev/null || true",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests yet\"",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "chariow",
    "ecommerce",
    "cli",
    "tui",
    "dashboard",
    "products",
    "sales",
    "analytics",
    "terminal",
    "command-line",
    "websocket",
    "realtime"
  ],
  "author": {
    "name": "Gopu Inc",
    "email": "contact@gopu.inc",
    "url": "https://gopu.inc"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gopu-inc/chariow-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/gopu-inc/chariow-sdk/issues"
  },
  "homepage": "https://github.com/gopu-inc/chariow-sdk#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1",
    "ws": "^8.14.2",
    "eventsource": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@types/inquirer": "^9.0.7",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/gopu-inc"
  }
}
