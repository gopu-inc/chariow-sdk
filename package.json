{
  "name": "chariow-sdk",
  "version": "2.1.3",
  "description": "Chariow SDK - Enterprise Commerce Platform",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "chariow": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js",
      "require": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "chmod +x dist/cli/index.js 2>/dev/null || true",
    "dev": "tsx src/cli/index.ts",
    "link:local": "npm link",
    "unlink:local": "npm unlink -g chariow-sdk"
  },
  "keywords": [
    "chariow",
    "ecommerce",
    "sdk",
    "api",
    "commerce"
  ],
  "author": "Chariow",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "ora": "^9.4.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
